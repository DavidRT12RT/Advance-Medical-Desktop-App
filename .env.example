# URL del servidor de IA (API Python con YOLO/Ollama).
# Este valor se embebe en el build (npm run make), igual que NEXT_PUBLIC_* en Next.js.
# Si no se define, la app usa http://localhost:8000 (API corriendo en la misma máquina).
#
# Cuando el servidor de IA central esté disponible, crear un archivo .env
# con la URL real antes de compilar, o definir la variable en CI.
VITE_API_SERVER_URL=http://localhost:8000
